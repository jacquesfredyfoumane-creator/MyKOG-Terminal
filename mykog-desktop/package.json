{
  "name": "mykog-desktop",
  "version": "1.0.0",
  "description": "MyKOG Desktop Application - Spotify-like interface",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac"
  },
  "keywords": [
    "electron",
    "mykog",
    "desktop"
  ],
  "author": "MyKOG Team",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "build": {
    "appId": "com.mykog.desktop",
    "productName": "MyKOG",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "src/assets/icons/icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "src/assets/icons/icon.png",
      "category": "AudioVideo"
    },
    "mac": {
      "target": "dmg",
      "icon": "src/assets/icons/icon.icns",
      "category": "public.app-category.music"
    }
  }
}
