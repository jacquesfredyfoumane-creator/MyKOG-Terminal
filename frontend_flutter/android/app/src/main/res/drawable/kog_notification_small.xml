    <!-- Utiliser le logo KOG avec un filtre pour le rendre visible dans les notifications -->
    <item>
        <bitmap
            android:src="@drawable/kog_launch"
            android:gravity="center"
            android:tint="@android:color/white" />
    </item>
</layer-list>

